# =========================
# IMPORTS
# =========================
from pathlib import Path
from collections import Counter
from getpass import getpass

import esm
from esm.sdk.api import ESMProtein, GenerationConfig

print("esm version:", esm.__version__)

# =========================
# CONFIG
# =========================
MODEL_NAME = "esm3-medium-2024-08"
TOKEN = getpass("Enter API key: ")

MASK_CHAR = "_"
WINDOW = 10
STEP = 10

N_SAMPLES = 20
TEMPERATURE = 0.5
NUM_STEPS = 8

FIRST_PASS_THRESHOLD = 0.8
FINAL_THRESHOLD = 0.6

OUTPUT_DIR = Path("pipeline_v1_thr_outputs")
OUTPUT_DIR.mkdir(exist_ok=True)

# =========================
# MODEL
# =========================
model = esm.sdk.client(MODEL_NAME, token=TOKEN)

# =========================
# INPUT
# =========================
ref_seq = "PUT_YOUR_REFERENCE_SEQUENCE_HERE"

# =========================
# HELPERS
# =========================
def build_masked_sequences(ref_seq, window, step):
    seqs = []
    n = len(ref_seq)

    for start in range(0, n, step):
        end = min(start + window, n)
        seq = list(ref_seq)

        for i in range(start, end):
            seq[i] = "_"

        seqs.append("".join(seq))

    return seqs

def masked_positions(seq):
    return [i for i, c in enumerate(seq) if c == "_"]

# =========================
# GENERATE
# =========================
def generate_predictions(masked_seq):
    preds = []

    for _ in range(N_SAMPLES):
        protein = ESMProtein(sequence=masked_seq)

        out = model.generate(
            protein,
            GenerationConfig(
                track="sequence",
                temperature=TEMPERATURE,
                num_steps=NUM_STEPS
            )
        )

        preds.append(out.sequence)

    return preds

# =========================
# 🔥 CONSENSUS (0.8)
# =========================
def consensus_line(masked_seq, preds, ref_seq):
    result = list(masked_seq)
    positions = masked_positions(masked_seq)

    for pos in positions:
        aa_list = [p[pos] for p in preds]
        count = Counter(aa_list)

        top_aa, top_count = count.most_common(1)[0]
        frac = top_count / len(preds)

        if frac >= FIRST_PASS_THRESHOLD:
            if top_aa == ref_seq[pos]:
                result[pos] = ref_seq[pos]
            else:
                result[pos] = "_"
        else:
            result[pos] = ref_seq[pos]

    return "".join(result)

def merge_lines(lines, ref_seq):
    merged = []

    for i in range(len(ref_seq)):
        if any(line[i] == "_" for line in lines):
            merged.append("_")
        else:
            merged.append(ref_seq[i])

    return "".join(merged)

def build_stages(merged, ref_seq):
    n = len(merged)
    mid = n // 2

    return {
        "full": merged,
        "front": merged[:mid] + ref_seq[mid:],
        "back": ref_seq[:mid] + merged[mid:]
    }

# =========================
# FINAL CONSENSUS
# =========================
def final_consensus(merged, ref_seq, all_preds):
    result = list(ref_seq)

    for i, ch in enumerate(merged):
        if ch == "_":
            aa_list = [seq[i] for seq in all_preds]
            count = Counter(aa_list)

            top_aa, top_count = count.most_common(1)[0]
            frac = top_count / len(all_preds)

            if frac >= FINAL_THRESHOLD and top_aa != ref_seq[i]:
                result[i] = top_aa
            else:
                result[i] = ref_seq[i]

    return "".join(result)

# =========================
# MAIN
# =========================
def run_pipeline():
    print("Building masks...")
    masked_seqs = build_masked_sequences(ref_seq, WINDOW, STEP)

    all_lines = []

    # ===== FIRST PASS =====
    for i, mseq in enumerate(masked_seqs):
        print(f"[Mask {i+1}/{len(masked_seqs)}]")

        preds = generate_predictions(mseq)

        line = consensus_line(
            masked_seq=mseq,
            preds=preds,
            ref_seq=ref_seq
        )

        all_lines.append(line)

    # ===== MERGE =====
    merged = merge_lines(all_lines, ref_seq)
    print("\nMerged:", merged)

    # ===== 3 STAGE =====
    stages = build_stages(merged, ref_seq)

    all_preds = []

    for name, seq in stages.items():
        print("Stage:", name)

        preds = generate_predictions(seq)
        all_preds.extend(preds)

    # ===== FINAL =====
    final = final_consensus(merged, ref_seq, all_preds)

    print("\nFinal:", final)

    return merged, final


merged, final = run_pipeline()
